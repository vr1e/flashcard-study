# Copy this file to `.env` and fill in real values for local development.
# In production (PythonAnywhere), set these as real environment variables.

# Django secret key — generate a new one for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-for-local-dev

# Set to True for local development, False in production.
DEBUG=True

# Comma-separated list of allowed hosts.
ALLOWED_HOSTS=127.0.0.1,localhost
